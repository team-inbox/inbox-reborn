{
  "name": "Inbox Reborn theme for Gmail™",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["storage"],
  "description": "Adds features like reminders, email bundling, and Inbox's minimalistic style to Gmail™",
  "homepage_url": "https://github.com/team-inbox/inbox-reborn",
  "action": {
    "default_popup": "src/options/options.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
"content_scripts": [
  {
    "matches": ["https://mail.google.com/*"],
    "js": ["src/script.js"],
    "css": ["src/style.css"],
    "run_at": "document_start"
  },
  {
    "matches": ["https://mail.google.com/*"],
    "js": ["src/header-colors.js"],
    "run_at": "document_idle"
  }
],
  "web_accessible_resources": [
    {
      "resources": [ "images/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
